# CALTEX MD Configuration
# ========================

# App Settings
APP_NAME=CALTEX MD
APP_URL=http://localhost:3000
APP_PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=file:./dev.db

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Bot Settings
BOT_PREFIX=!
BOT_NAME=CALTEX MD
BOT_OWNER=254104906247
BOT_SESSION_ID=default
BOT_AUTO_RECONNECT=true
BOT_MAX_RECONNECT_RETRIES=10
BOT_RECONNECT_DELAY=5000

# Anti-Features
ANTI_LINK=false
ANTI_BADWORD=false
ANTI_SPAM=false
ANTI_DELETE=false
ANTI_VIEW_ONCE=false
ANTI_TAG=false
ANTI_CALL=false
ANTI_BADWORDS_LIST=fuck,shit,damn,ass

# Auto Features
AUTO_READ=false
AUTO_TYPING=false
AUTO_RECORDING=false
AUTO_REACT=false
AUTO_STATUS_VIEWER=false

# Welcome/Goodbye
WELCOME_ENABLED=false
GOODBYE_ENABLED=false
WELCOME_MESSAGE=Welcome {user} to {group}!
GOODBYE_MESSAGE=Goodbye {user}! We'll miss you.

# AI Settings
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-sonnet-20240229
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
CUSTOM_AI_URL=
CUSTOM_AI_KEY=
CUSTOM_AI_MODEL=
AI_SYSTEM_PROMPT=You are CALTEX MD, a helpful WhatsApp assistant.
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048
AI_MEMORY_ENABLED=true
AI_MEMORY_LIMIT=20

# WebSocket
WS_PORT=3003

# Bot Service Port
BOT_SERVICE_PORT=3031

# Logging
LOG_LEVEL=info
LOG_FILE=logs/caltex-md.log

# Session
SESSION_DIR=sessions
SESSION_ENCRYPTION_KEY=change-this-encryption-key

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Backup
BACKUP_DIR=backups
AUTO_BACKUP=true
BACKUP_INTERVAL=86400000

# Media
MEDIA_DIR=media
MAX_MEDIA_SIZE=52428800

# Scheduled Messages
SCHEDULER_ENABLED=true
SCHEDULER_CHECK_INTERVAL=60000
