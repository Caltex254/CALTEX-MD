{
  "name": "caltex-md",
  "version": "1.1.0",
  "description": "CALTEX MD - Powerful WhatsApp Multi-Device Bot with AI, Plugin System, Web Dashboard & REST API",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "build": "next build",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "bun prisma/seed.ts",
    "bot:start": "cd mini-services/caltex-bot && bun index.ts",
    "bot:dev": "cd mini-services/caltex-bot && bun --hot index.ts",
    "ws:start": "cd mini-services/websocket-service && bun index.ts",
    "ws:dev": "cd mini-services/websocket-service && bun --hot index.ts",
    "services:start": "bun run bot:start & bun run ws:start",
    "services:dev": "bun run bot:dev & bun run ws:dev",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-accordion": "^1.2.17",
    "@radix-ui/react-alert-dialog": "^1.1.20",
    "@radix-ui/react-aspect-ratio": "^1.1.12",
    "@radix-ui/react-avatar": "^1.2.3",
    "@radix-ui/react-checkbox": "^1.3.8",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.3.4",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@radix-ui/react-hover-card": "^1.1.20",
    "@radix-ui/react-label": "^2.1.12",
    "@radix-ui/react-menubar": "^1.1.21",
    "@radix-ui/react-navigation-menu": "^1.2.19",
    "@radix-ui/react-popover": "^1.1.20",
    "@radix-ui/react-progress": "^1.1.13",
    "@radix-ui/react-radio-group": "^1.4.4",
    "@radix-ui/react-scroll-area": "^1.2.15",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-separator": "^1.1.12",
    "@radix-ui/react-slider": "^1.4.4",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.3.4",
    "@radix-ui/react-tabs": "^1.1.18",
    "@radix-ui/react-toast": "^1.2.20",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.16",
    "@radix-ui/react-tooltip": "^1.2.13",
    "@reactuses/core": "^6.4.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.42.2",
    "input-otp": "^1.4.2",
    "jose": "^6.2.3",
    "lucide-react": "^0.525.0",
    "next": "^16.2.10",
    "next-intl": "^4.13.2",
    "next-themes": "^0.4.6",
    "prisma": "^6.19.3",
    "react": "^19.2.7",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.82.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "recharts": "^2.15.4",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.1",
    "vaul": "^1.1.2",
    "z-ai-web-dev-sdk": "^0.0.18",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.14",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.2"
}
