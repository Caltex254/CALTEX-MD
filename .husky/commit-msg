#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# =============================================================================
# CALTEX MD - Commit Message Hook
# =============================================================================

MSG=$(cat "$1")

# Conventional commit pattern:
# feat|fix|docs|style|refactor|test|chore(scope): description
# or
# feat|fix|docs|style|refactor|test|chore: description
PATTERN="^(feat|fix|docs|style|refactor|test|chore)(\(.+\))?!?: .{1,100}"

if ! echo "$MSG" | grep -qE "$PATTERN"; then
  echo "❌ Invalid commit message format!"
  echo ""
  echo "Expected format:"
  echo "  <type>(<scope>): <description>"
  echo ""
  echo "Types: feat, fix, docs, style, refactor, test, chore"
  echo ""
  echo "Examples:"
  echo "  feat: add user authentication"
  echo "  fix(bot): resolve message parsing error"
  echo "  docs: update API documentation"
  echo "  style(dashboard): fix sidebar alignment"
  echo "  refactor: simplify database queries"
  echo "  test: add unit tests for auth module"
  echo "  chore(deps): update dependencies"
  echo ""
  echo "Breaking changes: append ! after type"
  echo "  feat!: redesign API endpoint structure"
  echo ""
  exit 1
fi

echo "✅ Commit message follows conventional format!"
