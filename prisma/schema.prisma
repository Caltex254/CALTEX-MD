// ============================================================
// CALTEX MD WhatsApp Bot - Prisma Database Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// Core Models
// ============================================================

model User {
  id            String    @id @default(cuid())
  jid           String    @unique
  name          String?
  pushName      String?
  profilePicUrl String?
  isPremium     Boolean   @default(false)
  premiumExpiry DateTime?
  isBanned      Boolean   @default(false)
  banReason     String?
  warnings      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  groupMembers  GroupMember[]
  warningsIssued Warning[]  @relation("WarnedByUser")
  auditLogs     AuditLog[]  @relation("AuditActor")

  @@index([jid])
  @@index([isBanned])
  @@index([isPremium])
}

model Group {
  id              String    @id @default(cuid())
  jid             String    @unique
  name            String?
  description     String?
  profilePicUrl   String?
  ownerJid        String?
  isBanned        Boolean   @default(false)
  welcomeEnabled  Boolean   @default(false)
  goodbyeEnabled  Boolean   @default(false)
  welcomeMessage  String?
  goodbyeMessage  String?
  antiLink        Boolean   @default(false)
  antiBadword     Boolean   @default(false)
  antiSpam        Boolean   @default(false)
  antiDelete      Boolean   @default(false)
  antiViewOnce    Boolean   @default(false)
  antiTag         Boolean   @default(false)
  antiCall        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  members         GroupMember[]
  warnings        Warning[]

  @@index([jid])
  @@index([isBanned])
}

model GroupMember {
  id        String   @id @default(cuid())
  groupJid  String
  userJid   String
  role      String   @default("member") // admin | member | owner | superadmin
  joinedAt  DateTime @default(now())

  // Relations
  group     Group    @relation(fields: [groupJid], references: [jid], onDelete: Cascade)
  user      User     @relation(fields: [userJid], references: [jid], onDelete: Cascade)

  @@unique([groupJid, userJid])
  @@index([groupJid])
  @@index([userJid])
  @@index([role])
}

// ============================================================
// Bot Session & Configuration
// ============================================================

model BotSession {
  id            String   @id @default(cuid())
  sessionId     String   @unique
  sessionData   String   // Auth state JSON
  status        String   @default("disconnected") // connected | disconnected | qr | banned
  phoneNumber   String?
  deviceName    String?
  lastActiveAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sessionId])
  @@index([status])
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  category    String?
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([category])
}

model Command {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String?
  category       String?
  isEnabled      Boolean  @default(true)
  usageCount     Int      @default(0)
  cooldown       Int      @default(0) // Cooldown in seconds
  isPremiumOnly  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([name])
  @@index([category])
  @@index([isEnabled])
}

model Plugin {
  id          String   @id @default(cuid())
  name        String   @unique
  version     String   @default("1.0.0")
  description String?
  author      String?
  isEnabled   Boolean  @default(true)
  filePath    String?
  config      String?  // JSON string for plugin configuration
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([isEnabled])
}

// ============================================================
// Logging & Statistics
// ============================================================

model Log {
  id        String   @id @default(cuid())
  level     String   @default("info") // info | warn | error | debug
  source    String?
  message   String
  data      String?  // Optional JSON payload
  createdAt DateTime @default(now())

  @@index([level])
  @@index([source])
  @@index([createdAt])
}

model Stat {
  id                String   @id @default(cuid())
  date              DateTime @unique
  messagesSent      Int      @default(0)
  messagesReceived  Int      @default(0)
  commandsExecuted  Int      @default(0)
  groupsActive      Int      @default(0)
  usersActive       Int      @default(0)
  apiCalls          Int      @default(0)
  errors            Int      @default(0)

  @@index([date])
}

// ============================================================
// Moderation
// ============================================================

model Warning {
  id        String   @id @default(cuid())
  userJid   String
  groupJid  String
  reason    String?
  warnedBy  String?
  createdAt DateTime @default(now())

  // Relations
  group     Group    @relation(fields: [groupJid], references: [jid], onDelete: Cascade)
  warner    User?    @relation("WarnedByUser", fields: [warnedBy], references: [jid], onDelete: SetNull)

  @@index([userJid])
  @@index([groupJid])
  @@index([createdAt])
}

model BlockedContact {
  id         String   @id @default(cuid())
  jid        String   @unique
  reason     String?
  blockedAt  DateTime @default(now())

  @@index([jid])
}

// ============================================================
// Messaging
// ============================================================

model Broadcast {
  id          String    @id @default(cuid())
  message     String
  targetType  String    @default("all") // all | groups | users
  status      String    @default("pending") // pending | sent | failed
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([status])
  @@index([targetType])
  @@index([scheduledAt])
}

model ScheduledMessage {
  id          String    @id @default(cuid())
  targetJid   String
  message     String
  mediaUrl    String?
  mediaType   String?   // image | video | audio | document | sticker
  scheduledAt DateTime
  isSent      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([targetJid])
  @@index([scheduledAt])
  @@index([isSent])
}

// ============================================================
// Custom Commands & AI
// ============================================================

model CustomCommand {
  id             String   @id @default(cuid())
  name           String
  trigger        String   // Regex or exact match pattern
  response       String
  category       String?
  isEnabled      Boolean  @default(true)
  isPremiumOnly  Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@unique([name])
  @@index([trigger])
  @@index([category])
  @@index([isEnabled])
}

model AISettings {
  id           String   @id @default(cuid())
  provider     String   @default("openai") // openai | gemini | claude | ollama | custom
  apiKey       String?
  model        String?
  systemPrompt String?
  temperature  Float    @default(0.7)
  maxTokens    Int      @default(4096)
  isEnabled    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([provider])
  @@index([isEnabled])
}

// ============================================================
// Media & Audit
// ============================================================

model MediaCache {
  id         String   @id @default(cuid())
  url        String   @unique
  filePath   String
  mediaType  String   // image | video | audio | document | sticker
  size       Int      @default(0) // Size in bytes
  accessedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([url])
  @@index([mediaType])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  actorJid  String?
  targetJid String?
  details   String?  // JSON payload with action-specific data
  createdAt DateTime @default(now())

  // Relations
  actor     User?    @relation("AuditActor", fields: [actorJid], references: [jid], onDelete: SetNull)

  @@index([action])
  @@index([actorJid])
  @@index([targetJid])
  @@index([createdAt])
}

// ============================================================
// Premium System
// ============================================================

model PremiumUser {
  id             String    @id @default(cuid())
  userJid        String    @unique
  plan           String    @default("basic") // basic | pro | enterprise
  startDate      DateTime  @default(now())
  expiryDate     DateTime
  isActive       Boolean   @default(true)
  grantedBy      String?   // JID of who granted premium
  autoRenew      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userJid])
  @@index([isActive])
  @@index([expiryDate])
}

// ============================================================
// Reminder System
// ============================================================

model Reminder {
  id          String   @id @default(cuid())
  userJid     String
  chatJid     String
  message     String
  remindAt    DateTime
  isRecurring Boolean  @default(false)
  recurrence  String?  // daily | weekly | monthly
  isSent      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userJid])
  @@index([remindAt])
  @@index([isSent])
}

// ============================================================
// Notes System
// ============================================================

model Note {
  id        String   @id @default(cuid())
  userJid   String
  title     String
  content   String
  isPrivate Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userJid])
}

// ============================================================
// Auto Reply System
// ============================================================

model AutoReply {
  id          String   @id @default(cuid())
  trigger     String   // Keyword or regex pattern
  response    String
  isRegex     Boolean  @default(false)
  isGlobal    Boolean  @default(true)
  groupJid    String?  // Null = global, otherwise group-specific
  isEnabled   Boolean  @default(true)
  matchCount  Int      @default(0)
  createdBy   String?
  createdAt   DateTime @default(now())

  @@index([trigger])
  @@index([groupJid])
  @@index([isEnabled])
}

// ============================================================
// AFK System
// ============================================================

model AFKStatus {
  id         String   @id @default(cuid())
  userJid    String   @unique
  reason     String   @default("No reason specified")
  isAFK      Boolean  @default(true)
  setAt      DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userJid])
  @@index([isAFK])
}

// ============================================================
// Multi-Language System
// ============================================================

model LanguagePack {
  id          String @id @default(cuid())
  code        String @unique // en, sw, fr, ar, etc.
  name        String // English, Kiswahili, French, etc.
  translations String // JSON string of key-value translations
  isDefault   Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
}

// ============================================================
// Theme System
// ============================================================

model ThemeConfig {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  style       String  // JSON string with theme styles/colors
  isDefault   Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

// ============================================================
// Owner Notifications
// ============================================================

model OwnerNotification {
  id         String   @id @default(cuid())
  type       String   // disconnect | session_expire | plugin_crash | db_error | api_failure | update_available
  title      String
  message    String
  severity   String   @default("info") // info | warn | error | critical
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

// ============================================================
// Update System
// ============================================================

model UpdateRecord {
  id           String   @id @default(cuid())
  fromVersion  String
  toVersion    String
  status       String   @default("pending") // pending | completed | failed | rolled_back
  backupPath   String?
  releaseNotes String?
  performedAt  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([status])
  @@index([performedAt])
}

// ============================================================
// Backup System
// ============================================================

model BackupRecord {
  id          String   @id @default(cuid())
  type        String   @default("full") // full | database | sessions | settings | plugins
  filePath    String
  size        Int      @default(0)
  isAuto      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

// ============================================================
// API Key Manager
// ============================================================

model APIKey {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "openai", "gemini"
  key         String   // Encrypted API key
  provider    String?
  isEnabled   Boolean  @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([provider])
  @@index([isEnabled])
}

// ============================================================
// Group Analytics
// ============================================================

model GroupAnalytics {
  id               String   @id @default(cuid())
  groupJid         String
  date             DateTime
  messagesCount    Int      @default(0)
  commandsCount    Int      @default(0)
  activeMembers    Int      @default(0)
  topContributor   String?
  createdAt        DateTime @default(now())

  @@unique([groupJid, date])
  @@index([groupJid])
  @@index([date])
}

// ============================================================
// Repo Configuration
// ============================================================

model RepoConfig {
  id              String   @id @default(cuid())
  repoName        String   @default("CALTEX MD")
  repoUrl         String?
  developerName   String   @default("CALTEX MD Team")
  description     String?
  docsUrl         String?
  license         String   @default("MIT")
  latestRelease   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
